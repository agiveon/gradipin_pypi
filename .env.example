# Copy this file to `.env` and fill in your real tokens.
# `.env` is gitignored — never commit it.

# ---- TestPyPI (./scripts/publish-testpypi.sh) ------------------------------
# Get a token at https://test.pypi.org/manage/account/token/
TWINE_USERNAME=__token__
TWINE_PASSWORD=pypi-AgEN...replace-me...

# ---- Real PyPI (./scripts/publish-pypi.sh) --------------------------------
# Get a token at https://pypi.org/manage/account/token/
# For the *first* publish use an account-scoped token; after that, delete it
# and create a project-scoped token for `gradipin`.
TWINE_USERNAME_PYPI=__token__
TWINE_PASSWORD_PYPI=pypi-AgEN...replace-me...

# ---- Optional: local dev overrides ---------------------------------------
# GRADIPIN_KEY=test-key
# GRADIPIN_API_URL=http://localhost:54321/functions/v1
